{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "inblock/map-block",
	"title": "Inblock Map Block",
	"category": "widgets",
	"icon": "location",
	"description": "Display an OpenStreetMap map.",
	"textdomain": "inblock-map-block",
	"supports": {
		"html": false,
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"__experimentalShadow": true
	},
	"attributes": {
		"lat": {
			"type": "number",
			"default": 48.8566
		},
		"lng": {
			"type": "number",
			"default": 2.3522
		},
		"zoom": {
			"type": "number",
			"default": 12
		},
		"height": {
			"type": "number",
			"default": 320
		},
		"markersEnabled": {
			"type": "boolean",
			"default": false
		},
		"markersPostType": {
			"type": "string",
			"default": ""
		},
		"markersSource": {
			"type": "string",
			"default": "acf_location"
		},
		"acfLocationField": {
			"type": "string",
			"default": "location"
		},
		"latMetaKey": {
			"type": "string",
			"default": "inblock_lat"
		},
		"lngMetaKey": {
			"type": "string",
			"default": "inblock_lng"
		},
		"markersLimit": {
			"type": "number",
			"default": 100
		},
		"markersPopup": {
			"type": "boolean",
			"default": true
		},
		"markersAutoFit": {
			"type": "boolean",
			"default": true
		},
		"markerStyle": {
			"type": "string",
			"default": "default"
		},
		"markerColor": {
			"type": "string",
			"default": "#2563eb"
		},
		"baseMap": {
			"type": "string",
			"default": "osm"
		},
		"showStartPosition": {
			"type": "boolean",
			"default": false
		},
		"markersCluster": {
			"type": "boolean",
			"default": true
		},
		"markersClusterMaxZoom": {
			"type": "number",
			"default": 17
		},
		"markersClusterDisableAtZoom": {
			"type": "number",
			"default": 18
		},
		"customBaseMapEnabled": {
			"type": "boolean",
			"default": false
		},
		"customBaseMapUrl": {
			"type": "string",
			"default": ""
		},
		"customBaseMapAttribution": {
			"type": "string",
			"default": ""
		},
		"markerDotSize": {
			"type": "number",
			"default": 6
		},
		"customMarkerEnabled": {
			"type": "boolean",
			"default": false
		},
		"customMarkerUrl": {
			"type": "string",
			"default": ""
		},
		"customMarkerWidth": {
			"type": "number",
			"default": 32
		},
		"customMarkerHeight": {
			"type": "number",
			"default": 32
		},
		"customMarkerAnchorX": {
			"type": "number",
			"default": 16
		},
		"customMarkerAnchorY": {
			"type": "number",
			"default": 32
		}
	},
	"editorScript": "file:./build/index.js",
	"style": "file:./build/style-index.css",
	"viewScript": "file:./build/view.js"
}
