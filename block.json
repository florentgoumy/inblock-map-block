{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "inblock/map-block",
  "title": "Inblock Map Block",
  "category": "widgets",
  "icon": "location",
  "description": "Display an OpenStreetMap map and plot items from a selected post type.",
  "textdomain": "inblock-map-block",
  "supports": {
    "html": false
  },
  "attributes": {
    "lat": { "type": "number", "default": 48.8566 },
    "lng": { "type": "number", "default": 2.3522 },
    "zoom": { "type": "number", "default": 12 }
  },
  "editorScript": "file:./build/index.js",
  "style": "file:./build/style-index.css",
  "viewScript": "file:./build/view.js"
}
